---
import Layout from '../../layouts/Layout.astro';

export const prerender = false;

export async function getStaticPaths() {
  return [
    {params: {section: "section1-html-css"}},
    {params: {section: "section2-javascript"}},
    {params: {section: "section3-backend"}},
    {params: {section: "section4-react"}},
  ];
}

const { section } = Astro.params;

// Fetch data
const API_BASE = 'http://localhost:8080/api';
let sectionData = null;
let allSections = [];
let error = null;

try {
  const [sectionResponse, allSectionsResponse] = await Promise.all([
    fetch(`${API_BASE}/sections/${section}`),
    fetch(`${API_BASE}/sections`)
  ]);
  
  sectionData = sectionResponse.ok ? await sectionResponse.json() : null;
  allSections = allSectionsResponse.ok ? await allSectionsResponse.json() : [];
  
  if (!sectionData) error = 'Section not found';
} catch (err) {
  error = 'Failed to connect to server';
}

// Prepare data for easier JSX usage
const sectionMeta = {
  "section1-html-css": { icon: "🌐", color: "blue", quarter: "Fall Quarter", courseCode: "CIS 241", difficulty: "Beginner", estimatedHours: 120 },
  "section2-javascript": { icon: "⚡", color: "green", quarter: "Winter Quarter", courseCode: "CIS 242", difficulty: "Intermediate", estimatedHours: 140 },
  "section3-backend": { icon: "🚀", color: "purple", quarter: "Spring Quarter", courseCode: "CIS 243", difficulty: "Intermediate", estimatedHours: 160 },
  "section4-react": { icon: "⚛️", color: "orange", quarter: "Summer Quarter", courseCode: "CIS 244", difficulty: "Advanced", estimatedHours: 150 }
};

const meta = sectionMeta[section] || sectionMeta["section1-html-css"];

// Pre-calculate values to avoid complex expressions in JSX
const lessonsCount = sectionData?.lessons?.length || 0;
const completion = Math.round((lessonsCount / 12) * 100);
const hoursCompleted = Math.round((completion / 100) * meta.estimatedHours);
const hoursRemaining = meta.estimatedHours - hoursCompleted;
const nextLesson = lessonsCount < 12 ? lessonsCount + 1 : null;

// Pre-generate CSS classes to avoid template literals in JSX
const headerGradient = `bg-gradient-to-r from-${meta.color}-600 to-${meta.color}-700`;
const borderColor = `border-${meta.color}-300`;
const bgColor = `bg-${meta.color}-100`;
const textColor = `text-${meta.color}-600`;
const buttonBg = `bg-${meta.color}-600`;
const buttonHover = `hover:bg-${meta.color}-700`;

// Overall progress calculation
const totalLessons = allSections.reduce((sum, sect) => sum + (sect.lessons?.length || 0), 0);
const overallCompletion = Math.round((totalLessons / 48) * 100);
const currentSectionIndex = allSections.findIndex(s => s.id === section) + 1;
---

<Layout title={sectionData ? `${sectionData.name} | Edmonds College` : 'Section Not Found'}>
  <div class="min-h-screen bg-gray-50">
    
    {/* Error State - Simple ternary */}
    {error ? (
      <div class="max-w-4xl mx-auto px-6 py-16">
        <div class="bg-red-50 border border-red-200 rounded-xl p-12 text-center">
          <h1 class="text-3xl font-bold text-red-800 mb-4">Section Not Available</h1>
          <p class="text-red-700 mb-8">{error}</p>
          <a href="/" class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700">
            Back to Home
          </a>
        </div>
      </div>
    ) : (
      /* Main Content */
      <div>
        {/* Section Header */}
        <div class={`${headerGradient} text-white`}>
          <div class="max-w-7xl mx-auto px-6 py-16">
            
            {/* Breadcrumb with Progress */}
            <div class="flex items-center justify-between mb-6">
              <nav>
                <ol class="flex items-center space-x-2 text-sm">
                  <li><a href="/" class="text-white opacity-80 hover:opacity-100">Home</a></li>
                  <li class="text-white opacity-60">/</li>
                  <li class="text-white font-medium">{sectionData?.name}</li>
                </ol>
              </nav>
              
              <div class="bg-white bg-opacity-20 backdrop-blur-sm rounded-lg px-4 py-2">
                <div class="flex items-center space-x-2 text-sm">
                  <span>Program Progress:</span>
                  <span class="font-bold">{overallCompletion}%</span>
                  <div class="w-16 bg-white bg-opacity-30 rounded-full h-2">
                    <div 
                      class="bg-white h-2 rounded-full transition-all duration-500"
                      style={`width: ${overallCompletion}%`}
                    ></div>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="grid lg:grid-cols-3 gap-8">
              {/* Main Section Info */}
              <div class="lg:col-span-2">
                <div class="flex items-center mb-6">
                  <span class="text-5xl mr-4">{meta.icon}</span>
                  <div>
                    <div class="flex items-center gap-3 mb-2">
                      <h1 class="text-4xl md:text-5xl font-bold">{sectionData?.name}</h1>
                      <span class="bg-white bg-opacity-20 backdrop-blur-sm px-3 py-1 rounded-full text-sm font-medium">
                        {meta.courseCode}
                      </span>
                    </div>
                    <div class="flex items-center gap-4 text-lg">
                      <span class="text-white opacity-90">{meta.quarter}</span>
                      <span class="bg-white bg-opacity-20 px-2 py-1 rounded text-sm">{meta.difficulty}</span>
                    </div>
                  </div>
                </div>
              </div>
              
              {/* Progress Card */}
              <div class="bg-white bg-opacity-10 backdrop-blur-sm rounded-xl p-6">
                <h3 class="text-lg font-bold mb-4">Section Progress</h3>
                <div class="space-y-4">
                  <div class="text-center">
                    <div class="text-3xl font-bold mb-2">{completion}%</div>
                    <div class="text-sm opacity-80">Complete</div>
                  </div>
                  
                  <div class="w-full bg-white bg-opacity-20 rounded-full h-3">
                    <div 
                      class="bg-white h-3 rounded-full transition-all duration-500"
                      style={`width: ${completion}%`}
                    ></div>
                  </div>
                  
                  <div class="flex justify-between text-sm">
                    <span>{lessonsCount} of 12 lessons</span>
                    <span>{hoursCompleted}h completed</span>
                  </div>
                  
                  {/* Next lesson or completion status */}
                  {nextLesson ? (
                    <div class="bg-white bg-opacity-20 rounded-lg p-3 text-center">
                      <div class="text-sm opacity-80">Up Next</div>
                      <div class="font-semibold">Week {nextLesson}</div>
                    </div>
                  ) : (
                    <div class="bg-green-500 bg-opacity-20 rounded-lg p-3 text-center">
                      <div class="font-semibold text-green-100">Section Complete!</div>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>

          {/* Progress Report Tab */}
          <div id="progress-tab" class="tab-content hidden">
            <div class="space-y-8">
              
              {/* Progress Summary Cards */}
              <div class="grid md:grid-cols-4 gap-6">
                <div class={`bg-${meta.color}-50 border border-${meta.color}-200 rounded-lg p-6 text-center`}>
                  <div class={`text-3xl font-bold text-${meta.color}-600 mb-2`}>{completion}%</div>
                  <div class="text-gray-700 text-sm">Section Complete</div>
                </div>
                
                <div class="bg-green-50 border border-green-200 rounded-lg p-6 text-center">
                  <div class="text-3xl font-bold text-green-600 mb-2">{hoursCompleted}</div>
                  <div class="text-gray-700 text-sm">Hours Completed</div>
                </div>
                
                <div class="bg-purple-50 border border-purple-200 rounded-lg p-6 text-center">
                  <div class="text-3xl font-bold text-purple-600 mb-2">{Math.round(meta.estimatedHours / 12)}</div>
                  <div class="text-gray-700 text-sm">Avg Hours/Week</div>
                </div>
                
                <div class="bg-orange-50 border border-orange-200 rounded-lg p-6 text-center">
                  <div class="text-3xl font-bold text-orange-600 mb-2">{overallCompletion}%</div>
                  <div class="text-gray-700 text-sm">Program Complete</div>
                </div>
              </div>
              
              {/* Skills Progress */}
              <div class="bg-white rounded-xl shadow-lg p-8">
                <h3 class="text-xl font-bold text-gray-800 mb-6">Skills Development</h3>
                <div class="space-y-4">
                  {section === "section1-html-css" && [
                    { skill: "HTML5 Elements", progress: Math.min(100, completion + 10) },
                    { skill: "CSS Styling", progress: Math.min(100, completion + 5) },
                    { skill: "Responsive Design", progress: Math.min(100, completion - 10) },
                    { skill: "Web Accessibility", progress: Math.min(100, completion - 15) }
                  ].map(({ skill, progress: skillProgress }) => (
                    <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                      <span class="font-medium text-gray-700">{skill}</span>
                      <div class="flex items-center space-x-3">
                        <div class="w-32 bg-gray-200 rounded-full h-2">
                          <div 
                            class={`bg-${meta.color}-500 h-2 rounded-full transition-all duration-500`}
                            style={`width: ${Math.max(0, skillProgress)}%`}
                          ></div>
                        </div>
                        <span class="text-sm text-gray-600 w-12">{Math.max(0, skillProgress)}%</span>
                      </div>
                    </div>
                  ))}
                  {section === "section2-javascript" && [
                    { skill: "JavaScript Fundamentals", progress: Math.min(100, completion + 15) },
                    { skill: "DOM Manipulation", progress: Math.min(100, completion + 5) },
                    { skill: "Event Handling", progress: Math.min(100, completion - 5) },
                    { skill: "Async Programming", progress: Math.min(100, completion - 20) }
                  ].map(({ skill, progress: skillProgress }) => (
                    <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                      <span class="font-medium text-gray-700">{skill}</span>
                      <div class="flex items-center space-x-3">
                        <div class="w-32 bg-gray-200 rounded-full h-2">
                          <div 
                            class={`bg-${meta.color}-500 h-2 rounded-full transition-all duration-500`}
                            style={`width: ${Math.max(0, skillProgress)}%`}
                          ></div>
                        </div>
                        <span class="text-sm text-gray-600 w-12">{Math.max(0, skillProgress)}%</span>
                      </div>
                    </div>
                  ))}
                  {section === "section3-backend" && [
                    { skill: "Node.js & Express", progress: Math.min(100, completion + 10) },
                    { skill: "Database Design", progress: Math.min(100, completion) },
                    { skill: "API Development", progress: Math.min(100, completion - 10) },
                    { skill: "Authentication", progress: Math.min(100, completion - 25) }
                  ].map(({ skill, progress: skillProgress }) => (
                    <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                      <span class="font-medium text-gray-700">{skill}</span>
                      <div class="flex items-center space-x-3">
                        <div class="w-32 bg-gray-200 rounded-full h-2">
                          <div 
                            class={`bg-${meta.color}-500 h-2 rounded-full transition-all duration-500`}
                            style={`width: ${Math.max(0, skillProgress)}%`}
                          ></div>
                        </div>
                        <span class="text-sm text-gray-600 w-12">{Math.max(0, skillProgress)}%</span>
                      </div>
                    </div>
                  ))}
                  {section === "section4-react" && [
                    { skill: "React Components", progress: Math.min(100, completion + 20) },
                    { skill: "State Management", progress: Math.min(100, completion + 5) },
                    { skill: "React Router", progress: Math.min(100, completion - 15) },
                    { skill: "Testing & Deployment", progress: Math.min(100, completion - 30) }
                  ].map(({ skill, progress: skillProgress }) => (
                    <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                      <span class="font-medium text-gray-700">{skill}</span>
                      <div class="flex items-center space-x-3">
                        <div class="w-32 bg-gray-200 rounded-full h-2">
                          <div 
                            class={`bg-${meta.color}-500 h-2 rounded-full transition-all duration-500`}
                            style={`width: ${Math.max(0, skillProgress)}%`}
                          ></div>
                        </div>
                        <span class="text-sm text-gray-600 w-12">{Math.max(0, skillProgress)}%</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
              
              {/* Time Analysis */}
              <div class="grid md:grid-cols-2 gap-8">
                <div class="bg-white rounded-xl shadow-lg p-8">
                  <h3 class="text-xl font-bold text-gray-800 mb-6">Time Analysis</h3>
                  <div class="space-y-4">
                    <div class="flex justify-between items-center">
                      <span class="text-gray-600">Total Estimated Hours</span>
                      <span class="font-bold text-gray-800">{meta.estimatedHours}h</span>
                    </div>
                    <div class="flex justify-between items-center">
                      <span class="text-gray-600">Hours Completed</span>
                      <span class="font-bold text-green-600">{hoursCompleted}h</span>
                    </div>
                    <div class="flex justify-between items-center">
                      <span class="text-gray-600">Hours Remaining</span>
                      <span class="font-bold text-orange-600">{hoursRemaining}h</span>
                    </div>
                    <div class="border-t pt-4">
                      <div class="flex justify-between items-center">
                        <span class="text-gray-600">Weekly Pace</span>
                        <span class="font-bold text-purple-600">{Math.round(meta.estimatedHours / 12)}h/week</span>
                      </div>
                    </div>
                    {completion < 100 && (
                      <div class="bg-blue-50 rounded-lg p-4 mt-4">
                        <div class="text-sm text-blue-800">
                          <strong>Estimated completion:</strong> {Math.ceil(hoursRemaining / (meta.estimatedHours / 12))} weeks remaining
                        </div>
                      </div>
                    )}
                  </div>
                </div>
                
                <div class="bg-white rounded-xl shadow-lg p-8">
                  <h3 class="text-xl font-bold text-gray-800 mb-6">Learning Path</h3>
                  <div class="space-y-3">
                    {Array.from({length: 4}, (_, i) => {
                      const sectionNames = ["HTML/CSS", "JavaScript", "Backend", "React"];
                      const sectionIds = ["section1-html-css", "section2-javascript", "section3-backend", "section4-react"];
                      const currentSectionIdx = sectionIds.indexOf(section);
                      const isCompleted = i < currentSectionIdx;
                      const isCurrent = i === currentSectionIdx;
                      const isUpcoming = i > currentSectionIdx;
                      
                      return (
                        <div class={`flex items-center p-3 rounded-lg ${
                          isCompleted ? 'bg-green-50 border border-green-200' :
                          isCurrent ? `bg-${meta.color}-50 border border-${meta.color}-200` :
                          'bg-gray-50 border border-gray-200'
                        }`}>
                          <div class={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold mr-3 ${
                            isCompleted ? 'bg-green-500 text-white' :
                            isCurrent ? `bg-${meta.color}-500 text-white` :
                            'bg-gray-300 text-gray-600'
                          }`}>
                            {isCompleted ? '✓' : i + 1}
                          </div>
                          <div class="flex-1">
                            <div class={`font-medium ${
                              isCompleted ? 'text-green-800' :
                              isCurrent ? `text-${meta.color}-800` :
                              'text-gray-600'
                            }`}>
                              Section {i + 1}: {sectionNames[i]}
                            </div>
                            <div class="text-xs text-gray-500">
                              {isCompleted ? 'Completed' : isCurrent ? 'In Progress' : 'Upcoming'}
                            </div>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Section Navigation */}
        <div class="bg-white border-b border-gray-200">
          <div class="max-w-7xl mx-auto px-6 py-4">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-semibold text-gray-800">All Sections</h3>
              <span class="text-sm text-gray-500">
                Section {currentSectionIndex} of 4
              </span>
            </div>
            
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              {allSections.map((sect, index) => {
                const sectMeta = sectionMeta[sect.id];
                const isCurrentSection = sect.id === section;
                const sectProgress = Math.round(((sect.lessons?.length || 0) / 12) * 100);
                const isComplete = (sect.lessons?.length || 0) === 12;
                
                // Pre-calculate classes to avoid template literals
                const cardClasses = isCurrentSection 
                  ? `bg-${sectMeta.color}-100 border-2 border-${sectMeta.color}-300`
                  : 'bg-gray-50 hover:bg-gray-100 border-2 border-transparent';
                
                const textClasses = isCurrentSection 
                  ? `text-${sectMeta.color}-800`
                  : 'text-gray-700';
                
                return (
                  <a 
                    href={isCurrentSection ? '#' : `/sections/${sect.id}`}
                    class={`relative p-4 rounded-lg transition-all duration-200 ${cardClasses}`}
                  >
                    <div class="flex items-center justify-between mb-2">
                      <span class="text-2xl">{sectMeta.icon}</span>
                      <div>
                        {isComplete && (
                          <span class="text-green-600 text-xs font-bold">✓ COMPLETE</span>
                        )}
                        {isCurrentSection && !isComplete && (
                          <span class={`text-${sectMeta.color}-600 text-xs font-bold`}>CURRENT</span>
                        )}
                      </div>
                    </div>
                    
                    <div class={`text-sm font-medium mb-2 ${textClasses}`}>
                      Section {index + 1}
                    </div>
                    
                    <div class="mb-3">
                      <div class="flex justify-between text-xs text-gray-600 mb-1">
                        <span>{sect.lessons?.length || 0}/12</span>
                        <span>{sectProgress}%</span>
                      </div>
                      <div class="w-full bg-gray-200 rounded-full h-2">
                        <div 
                          class={`bg-${sectMeta.color}-500 h-2 rounded-full transition-all duration-300`}
                          style={`width: ${sectProgress}%`}
                        ></div>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        </div>

        {/* Tab Navigation */}
        <div class="bg-white shadow-sm sticky top-0 z-10">
          <div class="max-w-7xl mx-auto px-6">
            <nav class="flex space-x-8">
              <button 
                class={`tab-btn py-4 px-2 border-b-2 border-${meta.color}-500 text-${meta.color}-600 font-medium text-sm`}
                data-tab="lessons"
              >
                Lessons ({lessonsCount})
              </button>
              <button 
                class="tab-btn py-4 px-2 border-b-2 border-transparent text-gray-500 font-medium text-sm"
                data-tab="syllabus"
              >
                Syllabus
              </button>
              <button 
                class="tab-btn py-4 px-2 border-b-2 border-transparent text-gray-500 font-medium text-sm"
                data-tab="schedule"
              >
                Weekly Schedule
              </button>
            </nav>
          </div>
        </div>

        {/* Tab Content */}
        <div class="max-w-7xl mx-auto px-6 py-8">
          
          {/* Lessons Tab */}
          <div id="lessons-tab" class="tab-content">
            {lessonsCount > 0 ? (
              <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                {sectionData.lessons.map((lesson, index) => {
                  const weekInSection = lesson.week - sectionData.week_start + 1;
                  const isRecent = index >= lessonsCount - 3;
                  
                  return (
                    <div class={`bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border-2 overflow-hidden ${
                      isRecent ? `border-${meta.color}-200` : 'border-gray-200'
                    }`}>
                      
                      {/* Lesson Header */}
                      <div class={`bg-gradient-to-r from-${meta.color}-500 to-${meta.color}-600 text-white p-4`}>
                        <div class="flex items-center justify-between">
                          <span class="bg-white bg-opacity-20 backdrop-blur-sm px-3 py-1 rounded-full text-sm font-medium">
                            Week {weekInSection}
                          </span>
                          <div class="flex items-center space-x-2">
                            <span class="text-2xl">{meta.icon}</span>
                            {isRecent && (
                              <span class="bg-yellow-400 text-yellow-900 px-2 py-1 rounded-full text-xs font-bold">
                                NEW
                              </span>
                            )}
                          </div>
                        </div>
                      </div>
                      
                      {/* Lesson Content */}
                      <div class="p-6">
                        <h3 class="text-xl font-bold text-gray-800 mb-3">
                          {lesson.title}
                        </h3>
                        
                        {lesson.description && (
                          <p class="text-gray-600 mb-4">
                            {lesson.description}
                          </p>
                        )}
                        
                        <div class="space-y-2 mb-4">
                          <div class="flex items-center justify-between text-sm text-gray-500">
                            <span>Global Week {lesson.week}</span>
                            <span>{new Date(lesson.created_at).toLocaleDateString()}</span>
                          </div>
                          
                          <div class="flex items-center text-sm text-gray-600">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <span>Est. {Math.round(meta.estimatedHours / 12)} hours</span>
                          </div>
                        </div>
                        
                        <a 
                          href={`/lessons/${lesson.week}`}
                          class={`block w-full text-center ${buttonBg} text-white px-4 py-3 rounded-lg ${buttonHover} transform hover:scale-105 transition-all duration-200 font-medium`}
                        >
                          Start Lesson
                        </a>
                      </div>
                    </div>
                  );
                })}
              </div>
            ) : (
              <div class="text-center py-16">
                <div class="text-8xl mb-6">📚</div>
                <h2 class="text-3xl font-bold text-gray-800 mb-4">Lessons Coming Soon</h2>
                <p class="text-xl text-gray-600 max-w-2xl mx-auto">
                  This section is being prepared with amazing content. Check back soon for new lessons!
                </p>
              </div>
            )}
          </div>

          {/* Syllabus Tab */}
          <div id="syllabus-tab" class="tab-content hidden">
            <div class="bg-white rounded-xl shadow-lg p-8">
              <h2 class="text-2xl font-bold text-gray-800 mb-4">Course Syllabus</h2>
              <p class="text-gray-600">Detailed syllabus content will be displayed here...</p>
            </div>
          </div>

          {/* Schedule Tab */}
          <div id="schedule-tab" class="tab-content hidden">
            <div class="bg-white rounded-xl shadow-lg p-8">
              <h2 class="text-2xl font-bold text-gray-800 mb-4">Weekly Schedule</h2>
              <p class="text-gray-600">Schedule content will be displayed here...</p>
            </div>
          </div>
        </div>
      </div>
    )}
  </div>
</Layout>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const tabButtons = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');
  
  // Get the section color from the page
  const getColorFromFirstTab = () => {
    const firstTabButton = document.querySelector('[data-tab="lessons"]');
    if (firstTabButton.className.includes('border-blue-500')) return 'blue';
    if (firstTabButton.className.includes('border-green-500')) return 'green';
    if (firstTabButton.className.includes('border-purple-500')) return 'purple';
    if (firstTabButton.className.includes('border-orange-500')) return 'orange';
    return 'blue'; // fallback
  };
  
  const sectionColor = getColorFromFirstTab();
  
  const switchTab = (targetTab) => {
    // Reset all buttons
    tabButtons.forEach(button => {
      button.classList.remove(
        'border-blue-500', 'text-blue-600',
        'border-green-500', 'text-green-600', 
        'border-purple-500', 'text-purple-600',
        'border-orange-500', 'text-orange-600'
      );
      button.classList.add('border-transparent', 'text-gray-500');
    });
    
    // Hide all tab contents using inline styles
    tabContents.forEach(content => {
      content.style.display = 'none';
    });
    
    // Show target content
    const targetContent = document.getElementById(targetTab + '-tab');
    if (targetContent) {
      targetContent.style.display = 'block';
    }
    
    // Activate target button
    const targetButton = document.querySelector(`[data-tab="${targetTab}"]`);
    if (targetButton) {
      targetButton.classList.add(`border-${sectionColor}-500`, `text-${sectionColor}-600`);
      targetButton.classList.remove('border-transparent', 'text-gray-500');
    }
  };
  
  // Add click listeners
  tabButtons.forEach(button => {
    button.addEventListener('click', function() {
      const tabName = this.getAttribute('data-tab');
      console.log('Switching to tab:', tabName); // Debug log
      switchTab(tabName);
    });
  });
  
  // Initialize with lessons tab
  console.log('Initializing tabs'); // Debug log
  switchTab('lessons');
});
</script>
</Layout>