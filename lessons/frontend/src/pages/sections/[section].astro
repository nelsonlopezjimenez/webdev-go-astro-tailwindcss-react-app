---
import Layout from '../../layouts/Layout.astro';

export const prerender = false;

export async function getStaticPaths() {
  return [
    {params: {section: "section1-html-css"}},
    {params: {section: "section2-javascript"}},
    {params: {section: "section3-backend"}},
    {params: {section: "section4-react"}},
  ];
}

const { section } = Astro.params;

// Fetch section data and calculate comprehensive progress metrics
const API_BASE = 'http://localhost:8080/api';
let sectionData = null;
let allSections = [];
let error = null;

try {
  const [sectionResponse, allSectionsResponse] = await Promise.all([
    fetch(`${API_BASE}/sections/${section}`),
    fetch(`${API_BASE}/sections`)
  ]);
  
  if (sectionResponse.ok) {
    sectionData = await sectionResponse.json();
  } else {
    error = 'Section not found';
  }
  
  if (allSectionsResponse.ok) {
    allSections = await allSectionsResponse.json();
  }
} catch (err) {
  error = 'Failed to connect to server';
}

// Enhanced metadata with progress calculations
const sectionMeta = {
  "section1-html-css": {
    icon: "🌐",
    color: "blue",
    quarter: "Fall Quarter",
    courseCode: "CIS 241",
    skills: ["HTML5", "CSS3", "Responsive Design", "Web Accessibility"],
    difficulty: "Beginner",
    estimatedHours: 120
  },
  "section2-javascript": {
    icon: "⚡",
    color: "green", 
    quarter: "Winter Quarter",
    courseCode: "CIS 242",
    skills: ["JavaScript ES6+", "DOM Manipulation", "Event Handling", "Async Programming"],
    difficulty: "Intermediate",
    estimatedHours: 140
  },
  "section3-backend": {
    icon: "🚀",
    color: "purple",
    quarter: "Spring Quarter",
    courseCode: "CIS 243",
    skills: ["Node.js", "Express", "Databases", "APIs"],
    difficulty: "Intermediate",
    estimatedHours: 160
  },
  "section4-react": {
    icon: "⚛️",
    color: "orange",
    quarter: "Summer Quarter", 
    courseCode: "CIS 244",
    skills: ["React", "State Management", "Routing", "Testing"],
    difficulty: "Advanced",
    estimatedHours: 150
  }
};

const meta = sectionMeta[section] || sectionMeta["section1-html-css"];

// Calculate progress metrics
function calculateProgress() {
  if (!sectionData) return { completion: 0, nextLesson: null, timeEstimate: 0 };
  
  const completion = (sectionData.lessons.length / 12) * 100;
  const nextWeek = sectionData.lessons.length + 1;
  const nextLesson = nextWeek <= 12 ? nextWeek : null;
  const hoursCompleted = Math.round((completion / 100) * meta.estimatedHours);
  const hoursRemaining = meta.estimatedHours - hoursCompleted;
  
  return {
    completion: Math.round(completion),
    nextLesson,
    hoursCompleted,
    hoursRemaining,
    averageWeeklyHours: Math.round(meta.estimatedHours / 12)
  };
}

const progress = calculateProgress();

// Calculate overall program progress
function calculateOverallProgress() {
  if (!allSections.length) return { totalLessons: 0, totalSections: 4, completedSections: 0 };
  
  const totalLessons = allSections.reduce((sum, section) => sum + section.lessons.length, 0);
  const completedSections = allSections.filter(section => section.lessons.length === 12).length;
  const totalPossibleLessons = 48; // 4 sections × 12 lessons
  const overallCompletion = Math.round((totalLessons / totalPossibleLessons) * 100);
  
  return {
    totalLessons,
    totalSections: 4,
    completedSections,
    overallCompletion,
    currentSection: allSections.findIndex(s => s.id === section) + 1
  };
}

const overallProgress = calculateOverallProgress();
---

<Layout title={sectionData ? `${sectionData.name} | Edmonds College` : 'Section Not Found'}>
  <div class="min-h-screen bg-gray-50">
    
    <!-- Error handling -->
    <div>
      {error && (
        <div class="max-w-4xl mx-auto px-6 py-16">
          <div class="bg-red-50 border border-red-200 rounded-xl p-12 text-center">
            <h1 class="text-3xl font-bold text-red-800 mb-4">Section Not Available</h1>
            <p class="text-red-700 mb-8">{error}</p>
            <a href="/" class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700">
              Back to Home
            </a>
          </div>
        </div>
      )}
    </div>

    <!-- Main content when no error -->
    <div>
      {!error && sectionData && (
        <div>
          <!-- Enhanced Section Header with Progress -->
          <div class={`bg-gradient-to-r from-${meta.color}-600 to-${meta.color}-700 text-white`}>
            <div class="max-w-7xl mx-auto px-6 py-16">
              
              <!-- Progress Breadcrumb -->
              <div class="flex items-center justify-between mb-6">
                <nav>
                  <ol class="flex items-center space-x-2 text-sm">
                    <li><a href="/" class="text-white opacity-80 hover:opacity-100">Home</a></li>
                    <li class="text-white opacity-60">/</li>
                    <li class="text-white font-medium">{sectionData.name}</li>
                  </ol>
                </nav>
                
                <!-- Overall Program Progress Indicator -->
                <div class="bg-white bg-opacity-20 backdrop-blur-sm rounded-lg px-4 py-2">
                  <div class="flex items-center space-x-2 text-sm">
                    <span>Program Progress:</span>
                    <span class="font-bold">{overallProgress.overallCompletion}%</span>
                    <div class="w-16 bg-white bg-opacity-30 rounded-full h-2">
                      <div 
                        class="bg-white h-2 rounded-full transition-all duration-500"
                        style={`width: ${overallProgress.overallCompletion}%`}
                      ></div>
                    </div>
                  </div>
                </div>
              </div>
              
              <div class="grid lg:grid-cols-4 gap-8">
                <!-- Main Section Info -->
                <div class="lg:col-span-2">
                  <div class="flex items-center mb-6">
                    <span class="text-5xl mr-4">{meta.icon}</span>
                    <div>
                      <div class="flex items-center gap-3 mb-2">
                        <h1 class="text-4xl md:text-5xl font-bold">{sectionData.name}</h1>
                        <span class="bg-white bg-opacity-20 backdrop-blur-sm px-3 py-1 rounded-full text-sm font-medium">
                          {meta.courseCode}
                        </span>
                      </div>
                      <div class="flex items-center gap-4 text-lg">
                        <span class="text-white opacity-90">{meta.quarter}</span>
                        <span class="bg-white bg-opacity-20 px-2 py-1 rounded text-sm">{meta.difficulty}</span>
                      </div>
                    </div>
                  </div>
                  
                  <!-- Skills Preview -->
                  <div class="mb-6">
                    <h3 class="text-lg font-semibold mb-3">Skills You'll Learn</h3>
                    <div class="flex flex-wrap gap-2">
                      {meta.skills.map((skill) => (
                        <span class="bg-white bg-opacity-20 backdrop-blur-sm px-3 py-1 rounded-full text-sm">
                          {skill}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
                
                <!-- Enhanced Progress Card -->
                <div class="lg:col-span-2 grid md:grid-cols-2 gap-4">
                  
                  <!-- Section Progress -->
                  <div class="bg-white bg-opacity-10 backdrop-blur-sm rounded-xl p-6">
                    <h3 class="text-lg font-bold mb-4">Section Progress</h3>
                    <div class="space-y-4">
                      <div class="text-center">
                        <div class="text-3xl font-bold mb-2">{progress.completion}%</div>
                        <div class="text-sm opacity-80">Complete</div>
                      </div>
                      
                      <div class="w-full bg-white bg-opacity-20 rounded-full h-3">
                        <div 
                          class="bg-white h-3 rounded-full transition-all duration-500"
                          style={`width: ${progress.completion}%`}
                        ></div>
                      </div>
                      
                      <div class="flex justify-between text-sm">
                        <span>{sectionData.lessons.length} of 12 lessons</span>
                        <span>{progress.hoursCompleted}h completed</span>
                      </div>
                      
                      <div>
                        {progress.nextLesson && (
                          <div class="bg-white bg-opacity-20 rounded-lg p-3 text-center">
                            <div class="text-sm opacity-80">Up Next</div>
                            <div class="font-semibold">Week {progress.nextLesson}</div>
                          </div>
                        )}
                        {!progress.nextLesson && (
                          <div class="bg-green-500 bg-opacity-20 rounded-lg p-3 text-center">
                            <div class="font-semibold text-green-100">Section Complete!</div>
                          </div>
                        )}
                      </div>
                    </div>
                  </div>
                  
                  <!-- Time Tracking -->
                  <div class="bg-white bg-opacity-10 backdrop-blur-sm rounded-xl p-6">
                    <h3 class="text-lg font-bold mb-4">Time Tracking</h3>
                    <div class="space-y-4">
                      <div class="flex justify-between">
                        <span class="text-sm opacity-80">Estimated Total</span>
                        <span class="font-semibold">{meta.estimatedHours}h</span>
                      </div>
                      
                      <div class="flex justify-between">
                        <span class="text-sm opacity-80">Hours Completed</span>
                        <span class="font-semibold text-green-200">{progress.hoursCompleted}h</span>
                      </div>
                      
                      <div class="flex justify-between">
                        <span class="text-sm opacity-80">Hours Remaining</span>
                        <span class="font-semibold">{progress.hoursRemaining}h</span>
                      </div>
                      
                      <div class="border-t border-white border-opacity-20 pt-3">
                        <div class="flex justify-between">
                          <span class="text-sm opacity-80">Avg per Week</span>
                          <span class="font-semibold">{progress.averageWeeklyHours}h</span>
                        </div>
                      </div>
                      
                      <div>
                        {progress.hoursRemaining > 0 && (
                          <div class="bg-white bg-opacity-20 rounded-lg p-3 text-center">
                            <div class="text-xs opacity-80">At current pace</div>
                            <div class="font-semibold">{Math.ceil(progress.hoursRemaining / progress.averageWeeklyHours)} weeks remaining</div>
                          </div>
                        )}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Section Navigation with Progress -->
          <div class="bg-white border-b border-gray-200">
            <div class="max-w-7xl mx-auto px-6 py-4">
              <div class="flex items-center justify-between">
                <h3 class="text-lg font-semibold text-gray-800">All Sections</h3>
                <span class="text-sm text-gray-500">
                  Section {overallProgress.currentSection} of {overallProgress.totalSections}
                </span>
              </div>
              
              <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-4">
                {allSections.map((sect, index) => {
                  const sectMeta = sectionMeta[sect.id];
                  const isCurrentSection = sect.id === section;
                  const sectProgress = Math.round((sect.lessons.length / 12) * 100);
                  const isComplete = sect.lessons.length === 12;
                  
                  return (
                    <a 
                      href={isCurrentSection ? '#' : `/sections/${sect.id}`}
                      class={`relative p-4 rounded-lg transition-all duration-200 ${
                        isCurrentSection 
                          ? `bg-${sectMeta.color}-100 border-2 border-${sectMeta.color}-300` 
                          : 'bg-gray-50 hover:bg-gray-100 border-2 border-transparent'
                      }`}
                    >
                      <div class="flex items-center justify-between mb-2">
                        <span class="text-2xl">{sectMeta.icon}</span>
                        <div>
                          {isComplete && (
                            <span class="text-green-600 text-xs font-bold">✓ COMPLETE</span>
                          )}
                          {isCurrentSection && !isComplete && (
                            <span class={`text-${sectMeta.color}-600 text-xs font-bold`}>CURRENT</span>
                          )}
                        </div>
                      </div>
                      
                      <div class={`text-sm font-medium mb-2 ${
                        isCurrentSection ? `text-${sectMeta.color}-800` : 'text-gray-700'
                      }`}>
                        Section {index + 1}
                      </div>
                      
                      <div class="mb-3">
                        <div class="flex justify-between text-xs text-gray-600 mb-1">
                          <span>{sect.lessons.length}/12</span>
                          <span>{sectProgress}%</span>
                        </div>
                        <div class="w-full bg-gray-200 rounded-full h-2">
                          <div 
                            class={`bg-${sectMeta.color}-500 h-2 rounded-full transition-all duration-300`}
                            style={`width: ${sectProgress}%`}
                          ></div>
                        </div>
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
          </div>

          <!-- Tab Navigation -->
          <div class="bg-white shadow-sm sticky top-0 z-10">
            <div class="max-w-7xl mx-auto px-6">
              <nav class="flex space-x-8">
                <button 
                  class={`tab-btn py-4 px-2 border-b-2 border-${meta.color}-500 text-${meta.color}-600 font-medium text-sm`}
                  data-tab="lessons"
                >
                  Lessons ({sectionData.lessons.length})
                </button>
                <button 
                  class="tab-btn py-4 px-2 border-b-2 border-transparent text-gray-500 font-medium text-sm"
                  data-tab="syllabus"
                >
                  Syllabus
                </button>
                <button 
                  class="tab-btn py-4 px-2 border-b-2 border-transparent text-gray-500 font-medium text-sm"
                  data-tab="schedule"
                >
                  Weekly Schedule
                </button>
                <button 
                  class="tab-btn py-4 px-2 border-b-2 border-transparent text-gray-500 font-medium text-sm"
                  data-tab="progress"
                >
                  Progress Report
                </button>
              </nav>
            </div>
          </div>

          <!-- Tab Content -->
          <div class="max-w-7xl mx-auto px-6 py-8">
            
            <!-- Enhanced Lessons Tab -->
            <div id="lessons-tab" class="tab-content">
              <div>
                {sectionData.lessons.length > 0 && (
                  <div>
                    <!-- Lessons Grid -->
                    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
                      {sectionData.lessons.map((lesson, index) => {
                        const weekInSection = lesson.week - sectionData.week_start + 1;
                        const isRecent = index >= sectionData.lessons.length - 3;
                        
                        return (
                          <div class={`bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border-2 overflow-hidden ${
                            isRecent ? `border-${meta.color}-200` : 'border-gray-200'
                          }`}>
                            
                            <!-- Enhanced Lesson Header -->
                            <div class={`bg-gradient-to-r from-${meta.color}-500 to-${meta.color}-600 text-white p-4`}>
                              <div class="flex items-center justify-between">
                                <span class="bg-white bg-opacity-20 backdrop-blur-sm px-3 py-1 rounded-full text-sm font-medium">
                                  Week {weekInSection}
                                </span>
                                <div class="flex items-center space-x-2">
                                  <span class="text-2xl">{meta.icon}</span>
                                  {isRecent && (
                                    <span class="bg-yellow-400 text-yellow-900 px-2 py-1 rounded-full text-xs font-bold">
                                      NEW
                                    </span>
                                  )}
                                </div>
                              </div>
                            </div>
                            
                            <!-- Enhanced Lesson Content -->
                            <div class="p-6">
                              <h3 class="text-xl font-bold text-gray-800 mb-3">
                                {lesson.title}
                              </h3>
                              
                              <div>
                                {lesson.description && (
                                  <p class="text-gray-600 mb-4">
                                    {lesson.description}
                                  </p>
                                )}
                              </div>
                              
                              <!-- Lesson Metadata -->
                              <div class="space-y-2 mb-4">
                                <div class="flex items-center justify-between text-sm text-gray-500">
                                  <span>Global Week {lesson.week}</span>
                                  <span>{new Date(lesson.created_at).toLocaleDateString()}</span>
                                </div>
                                
                                <div class="flex items-center text-sm text-gray-600">
                                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                  </svg>
                                  <span>Est. {progress.averageWeeklyHours} hours</span>
                                </div>
                              </div>
                              
                              <a 
                                href={`/lessons/${lesson.week}`}
                                class={`block w-full text-center bg-${meta.color}-600 text-white px-4 py-3 rounded-lg hover:bg-${meta.color}-700 transform hover:scale-105 transition-all duration-200 font-medium`}
                              >
                                Start Lesson
                              </a>
                            </div>
                          </div>
                        );
                      })}
                    </div>
                    
                    <!-- Next Lesson Preview -->
                    <div>
                      {progress.nextLesson && progress.nextLesson <= 12 && (
                        <div class="bg-gradient-to-r from-gray-50 to-gray-100 rounded-xl p-8 text-center">
                          <h3 class="text-2xl font-bold text-gray-800 mb-4">Up Next</h3>
                          <div class="flex items-center justify-center mb-4">
                            <span class="text-4xl mr-4">{meta.icon}</span>
                            <div>
                              <div class="text-lg font-semibold text-gray-700">
                                Week {progress.nextLesson}
                              </div>
                              <div class="text-sm text-gray-500">
                                Coming soon...
                              </div>
                            </div>
                          </div>
                          <p class="text-gray-600 mb-6">
                            The next lesson will be available soon. Keep checking back for updates!
                          </p>
                          <button class="bg-gray-400 text-white px-6 py-2 rounded-lg cursor-not-allowed">
                            Lesson Not Available
                          </button>
                        </div>
                      )}
                    </div>
                  </div>
                )}

                {sectionData.lessons.length === 0 && (
                  <div class="text-center py-16">
                    <div class="text-8xl mb-6">📚</div>
                    <h2 class="text-3xl font-bold text-gray-800 mb-4">Lessons Coming Soon</h2>
                    <p class="text-xl text-gray-600 max-w-2xl mx-auto">
                      This section is being prepared with amazing content. Check back soon for new lessons!
                    </p>
                  </div>
                )}
              </div>
            </div>

            <!-- Syllabus Tab (placeholder) -->
            <div id="syllabus-tab" class="tab-content hidden">
              <div class="bg-white rounded-xl shadow-lg p-8">
                <h2 class="text-2xl font-bold text-gray-800 mb-4">Course Syllabus</h2>
                <p class="text-gray-600">Detailed syllabus content will be displayed here...</p>
                <slot />
              </div>
            </div>

            <!-- Schedule Tab (placeholder) -->
            <div id="schedule-tab" class="tab-content hidden">
              <div class="bg-white rounded-xl shadow-lg p-8">
                <h2 class="text-2xl font-bold text-gray-800 mb-4">Weekly Schedule</h2>
                <p class="text-gray-600">Schedule content will be displayed here...</p>
              </div>
            </div>

            <!-- New Progress Report Tab -->
            <div id="progress-tab" class="tab-content hidden">
              <div class="space-y-8">
                
                <!-- Progress Summary -->
                <div class="bg-white rounded-xl shadow-lg p-8">
                  <h2 class="text-2xl font-bold text-gray-800 mb-6">Progress Summary</h2>
                  
                  <div class="grid md:grid-cols-3 gap-6">
                    <div class={`bg-${meta.color}-50 border border-${meta.color}-200 rounded-lg p-6 text-center`}>
                      <div class={`text-3xl font-bold text-${meta.color}-600 mb-2`}>{progress.completion}%</div>
                      <div class="text-gray-700">Section Complete</div>
                    </div>
                    
                    <div class="bg-green-50 border border-green-200 rounded-lg p-6 text-center">
                      <div class="text-3xl font-bold text-green-600 mb-2">{progress.hoursCompleted}</div>
                      <div class="text-gray-700">Hours Completed</div>
                    </div>
                    
                    <div class="bg-purple-50 border border-purple-200 rounded-lg p-6 text-center">
                      <div class="text-3xl font-bold text-purple-600 mb-2">{overallProgress.overallCompletion}%</div>
                      <div class="text-gray-700">Program Complete</div>
                    </div>
                  </div>
                </div>
                
                <!-- Skills Progress -->
                <div class="bg-white rounded-xl shadow-lg p-8">
                  <h3 class="text-xl font-bold text-gray-800 mb-6">Skills Development</h3>
                  <div class="grid md:grid-cols-2 gap-4">
                    {meta.skills.map((skill, index) => {
                      const skillProgress = Math.min(100, progress.completion + (index * 10));
                      return (
                        <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                          <span class="font-medium text-gray-700">{skill}</span>
                          <div class="flex items-center space-x-3">
                            <div class="w-20 bg-gray-200 rounded-full h-2">
                              <div 
                                class={`bg-${meta.color}-500 h-2 rounded-full transition-all duration-500`}
                                style={`width: ${skillProgress}%`}
                              ></div>
                            </div>
                            <span class="text-sm text-gray-600 w-12">{skillProgress}%</span>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const tabButtons = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');
  
  function switchTab(targetTab) {
    tabButtons.forEach(function(button) {
      button.classList.remove('border-blue-500', 'text-blue-600', 'border-green-500', 'text-green-600', 'border-purple-500', 'text-purple-600', 'border-orange-500', 'text-orange-600');
      button.classList.add('border-transparent', 'text-gray-500');
    });
    
    tabContents.forEach(function(content) {
      content.classList.add('hidden');
    });
    
    const targetContent = document.getElementById(targetTab + '-tab');
    if (targetContent) {
      targetContent.classList.remove('hidden');
    }
    
    const targetButton = document.querySelector('[data-tab="' + targetTab + '"]');
    if (targetButton) {
      // Get the section color from the first tab button (lessons tab)
      const firstTabButton = document.querySelector('[data-tab="lessons"]');
      const colorClasses = firstTabButton.className.match(/(border-\w+-\d+|text-\w+-\d+)/g);
      
      if (colorClasses) {
        colorClasses.forEach(function(colorClass) {
          targetButton.classList.add(colorClass);
        });
      }
      
      targetButton.classList.remove('border-transparent', 'text-gray-500');
    }
  }
  
  tabButtons.forEach(function(button) {
    button.addEventListener('click', function() {
      const tabName = this.getAttribute('data-tab');
      switchTab(tabName);
    });
  });
  
  switchTab('lessons');
});
</script>
</Layout>